/* custom-tab-bar/index.wxss */
.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 112rpx;
  background: #FFFFFF;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-around;
  box-shadow: 0 -2rpx 16rpx rgba(79, 184, 212, 0.12);
  padding-bottom: env(safe-area-inset-bottom);
  z-index: 999;
}

.tab-bar-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  flex: 1;
  padding: 12rpx 0;
  cursor: pointer;
  opacity: 0.6;
  transition: opacity 0.2s;
}

.tab-bar-item.active {
  opacity: 1;
}

.tab-emoji {
  font-size: 44rpx;
  line-height: 1.2;
  transition: transform 0.2s;
}

.tab-bar-item.active .tab-emoji {
  transform: scale(1.15);
}

.tab-text {
  font-size: 22rpx;
  color: #9BAAB8;
  margin-top: 4rpx;
  font-weight: 400;
}

.tab-bar-item.active .tab-text {
  color: #4FB8D4;
  font-weight: 600;
}
