<!-- pages/stats/stats.wxml - 统计页 -->
<view class="container">

  <!-- 顶部：视图模式切换（饼图 / 趋势） -->
  <view class="view-mode-switcher">
    <view
      class="view-mode-btn {{viewMode === 'pie' ? 'view-mode-active' : ''}}"
      data-mode="pie"
      bindtap="switchViewMode"
    >📊 分类</view>
    <view
      class="view-mode-btn {{viewMode === 'trend' ? 'view-mode-active' : ''}}"
      data-mode="trend"
      bindtap="switchViewMode"
    >📈 趋势</view>
  </view>

  <!-- ═══════ 饼图模式 ═══════ -->
  <block wx:if="{{viewMode === 'pie'}}">

    <!-- 月份切换栏 -->
    <view class="month-nav">
      <view class="month-arrow" bindtap="prevMonth">
        <text class="arrow-text">‹</text>
      </view>
      <text class="month-title">{{currentMonth}} 统计</text>
      <view class="month-arrow {{isCurrentMonth ? 'arrow-disabled' : ''}}" bindtap="nextMonth">
        <text class="arrow-text">›</text>
      </view>
    </view>

    <!-- 收支切换 -->
    <view class="type-switcher">
      <view
        class="type-btn {{statsType === 'expense' ? 'active-expense' : ''}}"
        data-type="expense"
        bindtap="switchStatsType"
      >💸 支出</view>
      <view
        class="type-btn {{statsType === 'income' ? 'active-income' : ''}}"
        data-type="income"
        bindtap="switchStatsType"
      >💰 收入</view>
    </view>

    <!-- 本月收支概览 -->
    <view class="summary-row">
      <view class="summary-item">
        <text class="summary-label">本月支出</text>
        <text class="summary-amount expense-text">¥{{monthExpense}}</text>
      </view>
      <view class="summary-divider"></view>
      <view class="summary-item">
        <text class="summary-label">本月收入</text>
        <text class="summary-amount income-text">¥{{monthIncome}}</text>
      </view>
    </view>

    <!-- 空状态 -->
    <view wx:if="{{isEmpty}}" class="empty-state">
      <text class="empty-emoji">🌸</text>
      <text class="empty-text">{{currentMonth}}暂无{{statsType === 'expense' ? '支出' : '收入'}}记录</text>
    </view>

    <!-- 图表区域 -->
    <view wx:else>

      <!-- Canvas 饼图（新版 2d context） -->
      <view class="chart-card">
        <canvas
          id="pieCanvas"
          type="2d"
          class="pie-canvas"
          style="width: 300px; height: 300px;"
        ></canvas>
        <!-- 降级旧 canvas -->
        <canvas
          canvas-id="pieCanvasLegacy"
          class="pie-canvas-legacy"
          style="width: 300px; height: 300px; display: none;"
        ></canvas>
      </view>

      <!-- 分类列表 -->
      <view class="card category-list">
        <text class="list-title">分类明细</text>
        <view
          class="category-row"
          wx:for="{{categoryList}}"
          wx:key="category"
        >
          <view class="cat-color-dot" style="background: {{item.color}};"></view>
          <view class="cat-info">
            <text class="cat-name">{{item.emoji}} {{item.category}}</text>
            <view class="progress-bar-wrap">
              <view class="progress-bar" style="width: {{item.percent}}%; background: {{item.color}};"></view>
            </view>
          </view>
          <view class="cat-right">
            <text class="cat-amount">¥{{item.amount}}</text>
            <text class="cat-percent">{{item.percent}}%</text>
          </view>
        </view>
      </view>

    </view>

  </block>

  <!-- ═══════ 趋势模式 ═══════ -->
  <block wx:elif="{{viewMode === 'trend'}}">

    <!-- 趋势标题 -->
    <view class="trend-header">
      <text class="trend-title">近 6 个月收支趋势</text>
      <text class="trend-subtitle">粉色柱 = 支出，蓝色柱 = 收入</text>
    </view>

    <!-- 趋势柱状图 Canvas -->
    <view class="chart-card trend-chart-card">
      <canvas
        id="trendCanvas"
        type="2d"
        class="trend-canvas"
        style="width: 340px; height: 220px;"
      ></canvas>
      <!-- 降级旧 canvas -->
      <canvas
        canvas-id="trendCanvasLegacy"
        class="trend-canvas-legacy"
        style="width: 340px; height: 220px; display: none;"
      ></canvas>
    </view>

    <!-- 月度明细列表 -->
    <view class="card trend-detail-list">
      <text class="list-title">月度明细</text>
      <view
        class="trend-detail-row"
        wx:for="{{trendData}}"
        wx:key="ym"
      >
        <text class="trend-detail-month">{{item.label}}</text>
        <view class="trend-detail-amounts">
          <view class="trend-amount-item">
            <text class="trend-amount-label expense-label">支出</text>
            <text class="trend-amount-val expense-text">¥{{item.expense}}</text>
          </view>
          <view class="trend-amount-item">
            <text class="trend-amount-label income-label">收入</text>
            <text class="trend-amount-val income-text">¥{{item.income}}</text>
          </view>
          <view class="trend-amount-item">
            <text class="trend-amount-label">结余</text>
            <text class="trend-amount-val {{item.net >= 0 ? 'income-text' : 'expense-text'}}">{{item.net >= 0 ? '+' : ''}}{{item.net}}</text>
          </view>
        </view>
      </view>
    </view>

  </block>

</view>
