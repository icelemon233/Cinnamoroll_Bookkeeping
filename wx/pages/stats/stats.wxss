/* pages/stats/stats.wxss */

/* 月份切换导航栏 */
.month-nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 8rpx 0 24rpx;
}

.month-arrow {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: #EBF7FB;
}

.arrow-text {
  font-size: 48rpx;
  color: #4FB8D4;
  font-weight: 700;
  line-height: 1;
  margin-top: -4rpx; /* 视觉居中微调 */
}

.arrow-disabled {
  opacity: 0.3;
}

.month-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #3D5A6E;
}

/* 收支概览卡片 */
.summary-row {
  display: flex;
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 28rpx 0;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(79, 184, 212, 0.1);
}

.summary-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.summary-divider {
  width: 1rpx;
  background: #EBF7FB;
  margin: 8rpx 0;
}

.summary-label {
  font-size: 24rpx;
  color: #9BAAB8;
  margin-bottom: 8rpx;
}

.summary-amount {
  font-size: 36rpx;
  font-weight: 700;
}

.income-text {
  color: #4FB8D4;
}

.expense-text {
  color: #FF8BAB;
}

/* 收支切换 */
.type-switcher {
  display: flex;
  background: #FFFFFF;
  border-radius: 100rpx;
  padding: 8rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(79, 184, 212, 0.1);
}

.type-btn {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  border-radius: 100rpx;
  font-size: 30rpx;
  color: #9BAAB8;
  transition: all 0.2s;
}

.active-expense {
  background: #FFE0E8;
  color: #FF8BAB;
  font-weight: 600;
}

.active-income {
  background: #E0F5FA;
  color: #4FB8D4;
  font-weight: 600;
}

/* 饼图卡片 */
.chart-card {
  background: #FFFFFF;
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(79, 184, 212, 0.12);
}

.pie-canvas {
  border-radius: 50%;
}

.pie-canvas-legacy {
  border-radius: 50%;
}

/* 分类明细列表 */
.category-list {
  padding: 28rpx;
}

.list-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #3D5A6E;
  display: block;
  margin-bottom: 24rpx;
}

.category-row {
  display: flex;
  align-items: center;
  padding: 18rpx 0;
  border-bottom: 1rpx solid #F0F8FF;
}

.category-row:last-child {
  border-bottom: none;
}

.cat-color-dot {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  flex-shrink: 0;
  margin-right: 16rpx;
}

.cat-info {
  flex: 1;
  margin-right: 20rpx;
}

.cat-name {
  font-size: 28rpx;
  color: #3D5A6E;
  display: block;
  margin-bottom: 8rpx;
}

.progress-bar-wrap {
  height: 8rpx;
  background: #F0F8FF;
  border-radius: 100rpx;
  overflow: hidden;
}

.progress-bar {
  height: 100%;
  border-radius: 100rpx;
  transition: width 0.5s ease;
}

.cat-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  flex-shrink: 0;
}

.cat-amount {
  font-size: 30rpx;
  font-weight: 700;
  color: #3D5A6E;
}

.cat-percent {
  font-size: 22rpx;
  color: #9BAAB8;
  margin-top: 4rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 0;
}

.empty-emoji {
  font-size: 100rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 30rpx;
  color: #9BAAB8;
}

/* ─── 视图模式切换（分类 / 趋势） ─────────────────────── */

.view-mode-switcher {
  display: flex;
  background: #FFFFFF;
  border-radius: 100rpx;
  padding: 8rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(79, 184, 212, 0.1);
}

.view-mode-btn {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  border-radius: 100rpx;
  font-size: 30rpx;
  color: #9BAAB8;
  transition: all 0.2s;
}

.view-mode-active {
  background: #E0F5FA;
  color: #4FB8D4;
  font-weight: 600;
}

/* ─── 趋势柱状图 ──────────────────────────────────────── */

.trend-header {
  padding: 4rpx 4rpx 20rpx;
}

.trend-title {
  display: block;
  font-size: 34rpx;
  font-weight: 700;
  color: #3D5A6E;
  margin-bottom: 8rpx;
}

.trend-subtitle {
  font-size: 24rpx;
  color: #9BAAB8;
}

.trend-chart-card {
  padding: 28rpx 16rpx;
}

.trend-canvas {
  display: block;
}

.trend-canvas-legacy {
  display: block;
}

/* ─── 趋势月度明细列表 ─────────────────────────────────── */

.trend-detail-list {
  padding: 28rpx;
  margin-bottom: 24rpx;
}

.trend-detail-row {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #F0F8FF;
}

.trend-detail-row:last-child {
  border-bottom: none;
}

.trend-detail-month {
  font-size: 32rpx;
  font-weight: 700;
  color: #3D5A6E;
  width: 72rpx;
  flex-shrink: 0;
}

.trend-detail-amounts {
  flex: 1;
  display: flex;
  justify-content: space-around;
}

.trend-amount-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.trend-amount-label {
  font-size: 22rpx;
  color: #9BAAB8;
  margin-bottom: 6rpx;
}

.expense-label {
  color: #FFB3C4;
}

.income-label {
  color: #88C8D8;
}

.trend-amount-val {
  font-size: 28rpx;
  font-weight: 600;
}

/* ─── 年度总览 ──────────────────────────────────────── */

.annual-summary-card {
  background: #FFFFFF;
  border-radius: 28rpx;
  padding: 32rpx 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(79, 184, 212, 0.12);
}

.annual-summary-row {
  display: flex;
  align-items: center;
  margin-bottom: 28rpx;
}

.annual-stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.annual-stat-divider {
  width: 1rpx;
  height: 64rpx;
  background: #EBF7FB;
  margin: 0 16rpx;
}

.annual-stat-label {
  font-size: 24rpx;
  color: #9BAAB8;
  margin-bottom: 8rpx;
}

.annual-stat-val {
  font-size: 36rpx;
  font-weight: 700;
}

.annual-net-row {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx 0;
  background: #F7FCFE;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
  gap: 16rpx;
}

.annual-net-label {
  font-size: 28rpx;
  color: #7A9AAB;
}

.annual-net-val {
  font-size: 38rpx;
  font-weight: 800;
}

.annual-highlight-row {
  display: flex;
  justify-content: space-around;
  padding-top: 8rpx;
}

.annual-highlight-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
}

.annual-highlight-emoji {
  font-size: 36rpx;
}

.annual-highlight-label {
  font-size: 22rpx;
  color: #9BAAB8;
}

.annual-highlight-month {
  font-size: 32rpx;
  font-weight: 700;
}

.annual-chart-card {
  padding: 24rpx 12rpx;
  margin-bottom: 24rpx;
}

.annual-canvas {
  display: block;
}

.annual-canvas-legacy {
  display: block;
}

.annual-detail-list {
  margin-bottom: 40rpx;
}

.annual-month-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #3D5A6E;
  width: 64rpx;
}

.zero-text {
  color: #C8DAE0;
}

/* ─── 智能分析卡片 ──────────────────────────────── */
.insight-card {
  margin-bottom: 24rpx;
  padding: 28rpx 28rpx 20rpx;
}

.insight-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.insight-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #3D5A6E;
}

.insight-days {
  font-size: 22rpx;
  color: #9BAAB8;
  background: #EBF7FB;
  padding: 4rpx 14rpx;
  border-radius: 20rpx;
}

.insight-stats-row {
  display: flex;
  align-items: center;
  justify-content: space-around;
  margin-bottom: 20rpx;
}

.insight-stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
  flex: 1;
}

.insight-stat-divider {
  width: 1rpx;
  height: 48rpx;
  background: #D8EEF5;
}

.insight-stat-label {
  font-size: 22rpx;
  color: #9BAAB8;
}

.insight-stat-val {
  font-size: 34rpx;
  font-weight: 700;
  color: #3D5A6E;
}

.insight-vs-row {
  display: flex;
  align-items: center;
  gap: 4rpx;
}

.insight-vs-arrow {
  font-size: 22rpx;
  font-weight: 700;
}

.vs-up {
  color: #FF6B8A;
}

.vs-down {
  color: #4FB8D4;
}

.insight-vs-pct {
  font-size: 32rpx;
  font-weight: 700;
}

.insight-tip-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
  background: #F5FAFE;
  border-radius: 16rpx;
  padding: 14rpx 18rpx;
}

.insight-tip-emoji {
  font-size: 30rpx;
  flex-shrink: 0;
}

.insight-tip-text {
  font-size: 24rpx;
  color: #5A7A8E;
  line-height: 1.5;
}
