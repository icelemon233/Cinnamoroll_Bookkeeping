/* pages/list/list.wxss */

/* ─── 搜索框 ─────────────────────────────────────────────── */
.search-bar {
  margin-bottom: 16rpx;
}

.search-inner {
  display: flex;
  align-items: center;
  background: #FFFFFF;
  border-radius: 100rpx;
  padding: 18rpx 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(79, 184, 212, 0.08);
}

.search-icon {
  font-size: 30rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #3D5A6E;
  height: 48rpx;
  line-height: 48rpx;
}

.search-placeholder {
  color: #C8D8E4;
}

.search-clear {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: #E8F4F8;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-left: 12rpx;
}

.clear-icon {
  font-size: 22rpx;
  color: #9BAAB8;
}

.search-result-hint {
  text-align: center;
  margin-bottom: 16rpx;
}

/* ─── 月份切换导航栏 ──────────────────────────────────────── */
.month-nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 8rpx 0 20rpx;
}

.month-arrow {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: #EBF7FB;
}

.arrow-text {
  font-size: 48rpx;
  color: #4FB8D4;
  font-weight: 700;
  line-height: 1;
  margin-top: -4rpx;
}

.arrow-disabled {
  opacity: 0.3;
}

.month-nav-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #3D5A6E;
}

/* ─── 顶部汇总 ───────────────────────────────────────────── */
.summary-bar {
  display: flex;
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 28rpx 36rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(79, 184, 212, 0.1);
  align-items: center;
  justify-content: center;
}

.summary-bar-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.bar-label {
  font-size: 24rpx;
  color: #9BAAB8;
  margin-bottom: 8rpx;
}

.bar-amount {
  font-size: 40rpx;
  font-weight: 700;
}

.bar-divider {
  width: 1rpx;
  height: 60rpx;
  background: #E8F4F8;
  margin: 0 20rpx;
}

.income-text { color: #4FB8D4; }
.expense-text { color: #FF8BAB; }

/* ─── 筛选行 ─────────────────────────────────────────────── */
.filter-row {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
  align-items: center;
}

.filter-btn {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  border-radius: 100rpx;
  font-size: 28rpx;
  color: #9BAAB8;
  background: #FFFFFF;
  border: 2rpx solid transparent;
  font-weight: 400;
  transition: all 0.2s;
}

.filter-active {
  background: #E0F5FA;
  color: #4FB8D4;
  border-color: #A8D8EA;
  font-weight: 600;
}

.filter-expense.filter-active {
  background: #FFE0E8;
  color: #FF8BAB;
  border-color: #FFB3C8;
}

.export-btn {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: #FFFFFF;
  border: 2rpx solid #E8F4F8;
  flex-shrink: 0;
}

.export-icon {
  font-size: 32rpx;
}

/* ─── 日期分组卡片 ────────────────────────────────────────── */
.date-group {
  padding: 20rpx 28rpx;
  margin-bottom: 20rpx;
}

.group-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #F0F8FF;
  margin-bottom: 8rpx;
}

.group-date {
  font-size: 26rpx;
  color: #9BAAB8;
  font-weight: 500;
}

.group-subtotal {
  display: flex;
  gap: 8rpx;
}

.subtotal-income {
  font-size: 26rpx;
  color: #4FB8D4;
}

.subtotal-expense {
  font-size: 26rpx;
  color: #FF8BAB;
}

/* ─── 账单条目 ───────────────────────────────────────────── */
.record-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #F8FCFE;
}

.record-item:last-child {
  border-bottom: none;
  padding-bottom: 4rpx;
}

.record-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: #EEF8FB;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.record-body {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.record-category {
  font-size: 30rpx;
  font-weight: 500;
  color: #3D5A6E;
}

.record-note {
  font-size: 24rpx;
  color: #9BAAB8;
  margin-top: 4rpx;
}

.record-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  flex-shrink: 0;
}

.record-amount {
  font-size: 34rpx;
  font-weight: 700;
}

.record-edit-hint {
  font-size: 20rpx;
  color: #C8D8E4;
  margin-top: 4rpx;
}

/* ─── 空状态 ─────────────────────────────────────────────── */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 0;
}

.empty-emoji {
  font-size: 100rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 30rpx;
  color: #9BAAB8;
  margin-bottom: 40rpx;
}

.add-btn {
  background: linear-gradient(135deg, #7EC8E3, #4FB8D4);
  color: #FFFFFF;
  padding: 24rpx 60rpx;
  border-radius: 100rpx;
  font-size: 30rpx;
  font-weight: 600;
}

.add-btn:active {
  opacity: 0.85;
}

/* ─── 分类筛选芯片 ──────────────────────────────────────── */
.category-chips-wrap {
  margin-bottom: 20rpx;
}

.category-chips-scroll {
  width: 100%;
  white-space: nowrap;
}

.category-chips-row {
  display: inline-flex;
  gap: 16rpx;
  padding: 4rpx 4rpx 8rpx;
}

.category-chip {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 14rpx 24rpx;
  border-radius: 100rpx;
  background: #FFFFFF;
  border: 2rpx solid #E8F4F8;
  flex-shrink: 0;
  transition: all 0.2s;
}

.category-chip:active {
  opacity: 0.75;
}

.chip-active {
  background: #E0F5FA;
  border-color: #A8D8EA;
}

.chip-emoji {
  font-size: 28rpx;
  line-height: 1;
}

.chip-text {
  font-size: 26rpx;
  color: #3D5A6E;
  font-weight: 500;
}

.chip-active .chip-text {
  color: #4FB8D4;
  font-weight: 600;
}

.chip-count {
  font-size: 22rpx;
  color: #9BAAB8;
  background: #F0F8FF;
  border-radius: 100rpx;
  padding: 2rpx 12rpx;
  min-width: 32rpx;
  text-align: center;
}

.chip-active .chip-count {
  background: #C8EEFA;
  color: #4FB8D4;
}

/* ─── 提示栏 ─────────────────────────────────────────────── */
.hint-bar {
  text-align: center;
  margin-bottom: 16rpx;
}

.hint-text {
  font-size: 24rpx;
  color: #B8D8E4;
}

/* ─── 账单详情弹窗 ──────────────────────────────────────── */
.detail-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(61, 90, 110, 0.45);
  z-index: 100;
  display: flex;
  align-items: flex-end;
}

.detail-card {
  width: 100%;
  background: #FFFFFF;
  border-radius: 40rpx 40rpx 0 0;
  padding: 20rpx 40rpx 60rpx;
  box-sizing: border-box;
  animation: slideUp 0.28s ease;
}

@keyframes slideUp {
  from { transform: translateY(100%); opacity: 0; }
  to { transform: translateY(0); opacity: 1; }
}

.detail-drag-bar {
  width: 80rpx;
  height: 8rpx;
  background: #DCE8EF;
  border-radius: 100rpx;
  margin: 0 auto 36rpx;
}

.detail-header {
  display: flex;
  align-items: center;
  gap: 32rpx;
  margin-bottom: 40rpx;
}

.detail-emoji-wrap {
  width: 112rpx;
  height: 112rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #E8F8FB, #D0F0F8);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.detail-emoji {
  font-size: 56rpx;
}

.detail-amount-wrap {
  display: flex;
  flex-direction: column;
}

.detail-amount {
  font-size: 56rpx;
  font-weight: 800;
  letter-spacing: -1rpx;
  line-height: 1.1;
}

.detail-type-label {
  font-size: 26rpx;
  color: #9BAAB8;
  margin-top: 6rpx;
}

.detail-info-list {
  background: #F6FBFD;
  border-radius: 24rpx;
  padding: 8rpx 28rpx;
  margin-bottom: 40rpx;
}

.detail-info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #EDF6FA;
}

.detail-info-row:last-child {
  border-bottom: none;
}

.detail-info-label {
  font-size: 28rpx;
  color: #9BAAB8;
  flex-shrink: 0;
}

.detail-info-value {
  font-size: 28rpx;
  color: #3D5A6E;
  font-weight: 500;
  text-align: right;
  max-width: 70%;
}

.detail-note-value {
  color: #5A7A8E;
  font-weight: 400;
}

.detail-actions {
  display: flex;
  gap: 24rpx;
}

.detail-action-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 28rpx 0;
  border-radius: 24rpx;
}

.detail-action-btn:active {
  opacity: 0.8;
}

.detail-edit-btn {
  background: linear-gradient(135deg, #C8EEFA, #A8D8EA);
}

.detail-delete-btn {
  background: linear-gradient(135deg, #FFE0E8, #FFCCD8);
}

.detail-action-icon {
  font-size: 36rpx;
}

.detail-action-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #3D5A6E;
}

.detail-edit-btn .detail-action-text {
  color: #3E90A6;
}

.detail-delete-btn .detail-action-text {
  color: #E06080;
}
