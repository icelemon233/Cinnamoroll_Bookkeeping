<!-- pages/list/list.wxml - 账单列表页 -->
<view class="container">

  <!-- 搜索框 -->
  <view class="search-bar">
    <view class="search-inner">
      <text class="search-icon">🔍</text>
      <input
        class="search-input"
        placeholder="搜索备注、分类、金额"
        placeholder-class="search-placeholder"
        value="{{searchKeyword}}"
        bindinput="onSearchInput"
        bindfocus="onSearchFocus"
        confirm-type="search"
      />
      <view wx:if="{{searchKeyword}}" class="search-clear" bindtap="clearSearch">
        <text class="clear-icon">✕</text>
      </view>
    </view>
  </view>

  <!-- 搜索模式：结果数提示 -->
  <view wx:if="{{isSearchMode}}" class="search-result-hint">
    <text class="hint-text">找到 {{searchResultCount}} 条结果</text>
  </view>

  <!-- 月份切换导航（搜索模式下隐藏） -->
  <view wx:if="{{!isSearchMode}}" class="month-nav">
    <view class="month-arrow" bindtap="prevMonth">
      <text class="arrow-text">‹</text>
    </view>
    <text class="month-nav-title">{{currentMonthLabel}}</text>
    <view class="month-arrow {{isLatestMonth ? 'arrow-disabled' : ''}}" bindtap="nextMonth">
      <text class="arrow-text">›</text>
    </view>
  </view>

  <!-- 顶部汇总（搜索模式下隐藏） -->
  <view wx:if="{{!isSearchMode}}" class="summary-bar">
    <view class="summary-bar-item">
      <text class="bar-label">收入</text>
      <text class="bar-amount income-text">+{{totalIncome}}</text>
    </view>
    <view class="bar-divider"></view>
    <view class="summary-bar-item">
      <text class="bar-label">支出</text>
      <text class="bar-amount expense-text">-{{totalExpense}}</text>
    </view>
  </view>

  <!-- 类型筛选 -->
  <view class="filter-row">
    <view class="filter-btn {{filterType === 'all' ? 'filter-active' : ''}}" data-type="all" bindtap="switchFilter">全部</view>
    <view class="filter-btn {{filterType === 'expense' ? 'filter-active filter-expense' : ''}}" data-type="expense" bindtap="switchFilter">支出</view>
    <view class="filter-btn {{filterType === 'income' ? 'filter-active filter-income' : ''}}" data-type="income" bindtap="switchFilter">收入</view>
    <view class="export-btn" bindtap="onExport">
      <text class="export-icon">📤</text>
    </view>
  </view>

  <!-- 分类筛选芯片（有分类数据时显示） -->
  <view wx:if="{{categoryChips.length > 0}}" class="category-chips-wrap">
    <scroll-view scroll-x class="category-chips-scroll" enhanced="{{true}}" show-scrollbar="{{false}}">
      <view class="category-chips-row">
        <view
          class="category-chip {{filterCategory === '' ? 'chip-active' : ''}}"
          bindtap="selectCategoryChip"
          data-name=""
        >
          <text class="chip-text">全部</text>
        </view>
        <view
          class="category-chip {{filterCategory === item.name ? 'chip-active' : ''}}"
          wx:for="{{categoryChips}}"
          wx:key="name"
          data-name="{{item.name}}"
          bindtap="selectCategoryChip"
        >
          <text class="chip-emoji">{{item.emoji}}</text>
          <text class="chip-text">{{item.name}}</text>
          <text class="chip-count">{{item.count}}</text>
        </view>
      </view>
    </scroll-view>
  </view>

  <!-- 操作提示 -->
  <view wx:if="{{!isEmpty && !isSearchMode}}" class="hint-bar">
    <text class="hint-text">长按账单可编辑或删除 ✨</text>
  </view>

  <!-- 空状态 -->
  <view wx:if="{{isEmpty}}" class="empty-state">
    <text class="empty-emoji">{{isSearchMode ? '🔍' : '🌸'}}</text>
    <text class="empty-text">{{isSearchMode ? '没找到相关账单' : currentMonthLabel + '暂无账单'}}</text>
    <view wx:if="{{!isSearchMode}}" class="add-btn" bindtap="goToAdd">
      <text>去记账 ✏️</text>
    </view>
  </view>

  <!-- 账单列表（按日期分组） -->
  <view wx:else>
    <view class="date-group card" wx:for="{{allGroups}}" wx:key="date">
      <view class="group-header">
        <text class="group-date">{{item.dateLabel}} ({{item.date}})</text>
        <view class="group-subtotal">
          <text wx:if="{{item.groupIncome > 0}}" class="subtotal-income">+{{item.groupIncome}}</text>
          <text wx:if="{{item.groupExpense > 0}}" class="subtotal-expense"> -{{item.groupExpense}}</text>
        </view>
      </view>
      <view
        class="record-item"
        wx:for="{{item.records}}"
        wx:for-item="record"
        wx:key="id"
        data-id="{{record.id}}"
        bindlongpress="onLongPress"
      >
        <view class="record-icon"><text>{{record.emoji}}</text></view>
        <view class="record-body">
          <text class="record-category">{{record.category}}</text>
          <text class="record-note" wx:if="{{record.note}}">{{record.note}}</text>
        </view>
        <view class="record-right">
          <text class="record-amount {{record.type === 'income' ? 'income-text' : 'expense-text'}}">{{record.amountDisplay}}</text>
          <text class="record-edit-hint">长按</text>
        </view>
      </view>
    </view>
  </view>

</view>
