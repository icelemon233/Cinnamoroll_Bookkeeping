<!-- custom-tab-bar/index.wxml -->
<view class="tab-bar">
  <view
    class="tab-bar-item {{selected === index ? 'active' : ''}}"
    wx:for="{{list}}"
    wx:key="pagePath"
    data-path="{{item.pagePath}}"
    data-index="{{index}}"
    bindtap="switchTab"
  >
    <text class="tab-emoji">{{item.emoji}}</text>
    <text class="tab-text">{{item.text}}</text>
  </view>
</view>
